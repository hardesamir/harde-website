---
layout: layout.njk
title: Gallery
permalink: /gallery/
---

<div class="container">
    <a href="/" class="back-btn"><i class="fas fa-arrow-left"></i> Back to Home</a>

    <!-- Gallery Grid -->
    <div class="gallery-grid" id="galleryGrid">
        {% for image in collections.galleryImages %}
        <div class="gallery-card" data-category="all">
            <div class="card-image">
                <img src="{{ image.url }}" alt="{{ image.fileSlug or 'Gallery Image' }}" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
                <div class="placeholder" style="display: none;">
                    <i class="fas fa-image"></i>
                    {{ image.fileSlug or 'Image' }}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    {% if collections.galleryImages.length == 0 %}
    <div class="gallery-empty">
        <p><i class="fas fa-camera"></i></p>
        <p>No images in gallery yet.</p>
        <p class="gallery-empty-hint">Add images to the <code>images/gallery/</code> folder to see them here.</p>
    </div>
    {% endif %}

    <!-- Loading Animation -->
    <div class="loading" id="loading">
        <div class="spinner"></div>
        <p>Loading gallery...</p>
    </div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
    <span class="lightbox-close" id="lightboxClose">&times;</span>
    <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous" style="display:none;">&#8592;</button>
    <div class="lightbox-content">
        <img class="lightbox-image" id="lightboxImage" src="" alt="">
        <div class="lightbox-caption" id="lightboxCaption"></div>
    </div>
    <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next" style="display:none;">&#8594;</button>
</div>

<style>
/* Gallery Page Styles */
.container {
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
    padding: 6rem 2rem 2rem 2rem;
}

.back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    color: var(--color-gold, #c9930d);
    border: 1px solid var(--color-border, rgba(201, 147, 13, 0.12));
    border-radius: var(--radius-full, 9999px);
    padding: 0.6rem 1.5rem;
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    margin-bottom: 2rem;
    margin-top: 1rem;
    transition: all var(--transition, 0.4s ease);
}

.back-btn:hover {
    background: var(--color-gold, #c9930d);
    color: #000;
    border-color: var(--color-gold, #c9930d);
}

/* Gallery Grid */
.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
}

.gallery-card {
    background: var(--color-surface, #141414);
    border-radius: var(--radius-md, 16px);
    overflow: hidden;
    transition: transform var(--transition, 0.4s ease), box-shadow var(--transition, 0.4s ease), border-color var(--transition, 0.4s ease);
    cursor: pointer;
    border: 1px solid var(--color-border, rgba(201, 147, 13, 0.12));
}

.gallery-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
    border-color: var(--color-border-hover, rgba(201, 147, 13, 0.3));
}

.card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-surface, #141414);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.gallery-card:hover .card-image img {
    transform: scale(1.06);
}

.card-image .placeholder {
    color: var(--color-text-subtle, #666);
    font-size: 0.9rem;
    text-align: center;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
    gap: 0.5rem;
}

.card-image .placeholder i {
    font-size: 2rem;
    color: var(--color-text-subtle, #666);
}

.gallery-empty {
    text-align: center;
    color: var(--color-text-muted, #999);
    font-size: 1.1rem;
    margin-top: 3rem;
}

.gallery-empty i {
    font-size: 2rem;
    color: var(--color-gold, #c9930d);
    margin-bottom: 0.5rem;
}

.gallery-empty-hint {
    font-size: 0.85rem;
    margin-top: 0.75rem;
    color: var(--color-text-subtle, #666);
}

.gallery-empty code {
    background: var(--color-surface, #141414);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.85rem;
}

/* Lightbox */
.lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 2000;
    justify-content: center;
    align-items: center;
}

.lightbox.active {
    display: flex;
}

.lightbox-content {
    width: 100vw;
    height: 100vh;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0;
}

.lightbox-image {
    max-width: 92vw;
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    margin: 0 auto;
    border-radius: var(--radius-sm, 8px);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.6);
}

.lightbox-caption {
    color: var(--color-text-muted, #999);
    font-size: 0.9rem;
    margin-top: 1rem;
    padding: 0.4rem 1.2rem;
    text-align: center;
    max-width: 90vw;
}

.lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2100;
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text, #f0f0f0);
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 1.5rem;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
}

.lightbox-arrow:hover {
    background: var(--color-gold, #c9930d);
    color: #000;
    border-color: var(--color-gold, #c9930d);
}

.lightbox-prev { left: 1.5rem; }
.lightbox-next { right: 1.5rem; }

.lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    color: var(--color-text, #f0f0f0);
    font-size: 1.5rem;
    cursor: pointer;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    z-index: 2100;
}

.lightbox-close:hover {
    background: var(--color-gold, #c9930d);
    color: #000;
    border-color: var(--color-gold, #c9930d);
}

/* Loading */
.loading {
    text-align: center;
    padding: 2rem;
    display: none;
    color: var(--color-text-muted, #999);
}

.loading.active { display: block; }

.spinner {
    border: 3px solid var(--color-surface, #141414);
    border-top: 3px solid var(--color-gold, #c9930d);
    border-radius: 50%;
    width: 36px;
    height: 36px;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 1rem;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Responsive */
@media (max-width: 768px) {
    .container {
        padding: 5rem 1rem 1rem;
    }
    .gallery-grid {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
    }
    .lightbox-arrow {
        width: 42px;
        height: 42px;
        font-size: 1.2rem;
    }
    .lightbox-prev { left: 0.75rem; }
    .lightbox-next { right: 0.75rem; }
}

@media (max-width: 480px) {
    .gallery-grid {
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }
    .card-image {
        aspect-ratio: 1 / 1;
    }
}
</style>

<script>
// Filter functionality
const filterButtons = document.querySelectorAll('.filter-btn');
const galleryCards = document.querySelectorAll('.gallery-card');
const loading = document.getElementById('loading');

filterButtons.forEach(btn => {
    btn.addEventListener('click', function() {
        filterButtons.forEach(button => button.classList.remove('active'));
        this.classList.add('active');
        const filter = this.getAttribute('data-filter');
        loading.classList.add('active');
        setTimeout(() => {
            galleryCards.forEach(card => {
                const category = card.getAttribute('data-category');
                if (filter === 'all' || category === filter) {
                    card.style.display = 'block';
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    setTimeout(() => {
                        card.style.opacity = '1';
                        card.style.transform = 'translateY(0)';
                    }, 100);
                } else {
                    card.style.opacity = '0';
                    card.style.transform = 'translateY(20px)';
                    setTimeout(() => {
                        card.style.display = 'none';
                    }, 300);
                }
            });
            loading.classList.remove('active');
        }, 300);
    });
});

// Lightbox with navigation
const lightbox = document.getElementById('lightbox');
const lightboxImage = document.getElementById('lightboxImage');
const lightboxCaption = document.getElementById('lightboxCaption');
const lightboxClose = document.getElementById('lightboxClose');
const lightboxPrev = document.getElementById('lightboxPrev');
const lightboxNext = document.getElementById('lightboxNext');
let currentIndex = -1;
const images = Array.from(document.querySelectorAll('.gallery-card img'));
const cards = Array.from(document.querySelectorAll('.gallery-card'));

function showLightbox(idx) {
    if (idx < 0 || idx >= images.length) return;
    const img = images[idx];
    if (!img || img.style.display === 'none') return;
    lightboxImage.src = img.src;
    lightboxImage.alt = img.alt;
    lightboxImage.style.display = 'block';
    let caption = img.alt || img.src.split('/').pop();
    lightboxCaption.textContent = caption;
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    currentIndex = idx;
    if (images.length > 1) {
        lightboxPrev.style.display = '';
        lightboxNext.style.display = '';
    } else {
        lightboxPrev.style.display = 'none';
        lightboxNext.style.display = 'none';
    }
}

cards.forEach((card, idx) => {
    card.addEventListener('click', () => showLightbox(idx));
});

lightboxPrev.addEventListener('click', function(e) {
    e.stopPropagation();
    let idx = currentIndex;
    do { idx = (idx - 1 + images.length) % images.length; }
    while (images[idx].style.display === 'none' && idx !== currentIndex);
    if (idx !== currentIndex) showLightbox(idx);
});

lightboxNext.addEventListener('click', function(e) {
    e.stopPropagation();
    let idx = currentIndex;
    do { idx = (idx + 1) % images.length; }
    while (images[idx].style.display === 'none' && idx !== currentIndex);
    if (idx !== currentIndex) showLightbox(idx);
});

function closeLightbox() {
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
    currentIndex = -1;
}

lightboxClose.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

document.addEventListener('keydown', function(e) {
    if (lightbox.classList.contains('active')) {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') lightboxPrev.click();
        if (e.key === 'ArrowRight') lightboxNext.click();
    }
});

// Swipe/drag navigation for lightbox
(function() {
    let startX = 0, endX = 0, dragging = false;
    const img = lightboxImage;
    img.addEventListener('touchstart', (e) => { if (lightbox.classList.contains('active')) { dragging = true; startX = e.touches[0].clientX; } });
    img.addEventListener('touchmove', (e) => { if (dragging) endX = e.touches[0].clientX; });
    img.addEventListener('touchend', () => { if (!dragging) return; dragging = false; if (endX - startX > 60) lightboxPrev.click(); else if (startX - endX > 60) lightboxNext.click(); startX = endX = 0; });
    img.addEventListener('mousedown', (e) => { if (lightbox.classList.contains('active')) { dragging = true; startX = e.clientX; } });
    img.addEventListener('mousemove', (e) => { if (dragging) endX = e.clientX; });
    img.addEventListener('mouseup', () => { if (!dragging) return; dragging = false; if (endX - startX > 60) lightboxPrev.click(); else if (startX - endX > 60) lightboxNext.click(); startX = endX = 0; });
    img.addEventListener('mouseleave', () => { dragging = false; startX = endX = 0; });
})();

// Transition setup
galleryCards.forEach(card => { card.style.transition = 'all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94)'; });

// Image error handling
document.querySelectorAll('.gallery-card img').forEach(img => {
    img.addEventListener('error', function() {
        this.style.display = 'none';
        const placeholder = this.nextElementSibling;
        if (placeholder && placeholder.classList.contains('placeholder')) {
            placeholder.style.display = 'flex';
        }
    });
});
</script>
